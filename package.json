{
  "name": "@doitintl/doit-mcp-server",
  "version": "0.11.0",
  "description": "DoiT official MCP Server",
  "keywords": [
    "doit",
    "mcp",
    "mcp-server"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "compile": "tsc",
    "build": "cd widget && npm install --prefer-offline --no-audit && npm run build && cd .. && node scripts/inline-widget.mjs && tsc && shx chmod +x dist/*.js",
    "watch": "tsc --watch",
    "test": "vitest run",
    "deploy": "yarn build && npm publish --access public",
    "type-check": "tsc --noEmit",
    "lint": "biome lint src/ test/",
    "lint:fix": "biome lint --write src/ test/",
    "format": "biome format src/ test/",
    "format:fix": "biome format --write src/ test/",
    "check:dev": "yarn type-check && biome check src/ test/",
    "check:ci": "yarn type-check && biome ci src/ test/",
    "check:fix": "biome check --write src/ test/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "3.24.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22",
    "shx": "^0.3.4",
    "typescript": "^5.7.2",
    "vitest": "~3.1.3"
  },
  "engines": {
    "node": ">=18"
  }
}
